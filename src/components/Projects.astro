---
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL;
---

<section class="grid grid-cols-1 gap-8 px-[4vw] py-[32vw] md:grid-cols-2 md:gap-x-6 md:pb-[50vh]">
  {
    allProjects.map((it, i) => (
      <a
        href={`${base}/projects/${it.id}`}
        class={`group ${i % 2 !== 0 ? 'md:translate-y-1/2' : ''}`}
      >
        <div class="relative aspect-video overflow-clip">
          {it.data.thumbnail && (
            <img
              src={`${base}/assets/${it.data.thumbnail}`}
              alt={it.data.title}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            />
          )}
          <div class="absolute inset-0 m-2 border border-white opacity-0 transition-opacity group-hover:opacity-70" />
          <div class="absolute inset-y-0 right-1/4 my-2 border border-white opacity-0 transition-opacity group-hover:opacity-70" />
          <div class="absolute inset-x-0 top-1/3 mx-2 border border-white opacity-0 transition-opacity group-hover:opacity-70" />

          <div class="absolute inset-0 transition-colors duration-300 group-hover:bg-linear-45 group-hover:from-black group-hover:to-transparent" />
          <div class="absolute inset-y-0 left-0 flex w-3/4 flex-col p-3 text-white transition-colors">
            <span class="text-[1.75vw]/[1.5vw] text-white/20 uppercase transition-colors group-hover:text-white">
              {it.data.location} [{it.data.year}]
            </span>

            <h2 class="group-hover:text-accent mt-auto text-left text-[3vw]/[2.5vw] tracking-normal text-pretty">
              {it.data.title}
            </h2>
          </div>
          <div class="absolute inset-0 flex flex-col justify-start p-3 text-white/20 transition-colors group-hover:text-white">
            {/* <span class="font-almarai text-right text-6xl text-pretty">PROJECT</span> */}
            <span class="font-almarai text-right text-9xl text-pretty">#{it.data.order}</span>
          </div>
        </div>
      </a>
    ))
  }
</section>
